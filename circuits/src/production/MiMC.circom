template MiMCHash(nInputs) {
    signal input inputs[nInputs];
    signal output out;
    
    component mimc[nInputs];
    
    mimc[0] = MiMC7(91);
    mimc[0].x_in <== inputs[0];
    mimc[0].k <== 0;
    
    for (var i = 1; i < nInputs; i++) {
        mimc[i] = MiMC7(91);
        mimc[i].x_in <== inputs[i];
        mimc[i].k <== mimc[i-1].out;
    }
    
    out <== mimc[nInputs-1].out;
}