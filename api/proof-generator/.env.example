# Server Configuration
NODE_ENV=production
PORT=8080

# Google Cloud Storage
USE_CLOUD_STORAGE=true
CIRCUIT_BUCKET=lockx-zk-circuits
GOOGLE_CLOUD_PROJECT=your-project-id

# CORS Settings
ALLOWED_ORIGINS=https://lockx.io,https://app.lockx.io

# Performance
PRELOAD_CIRCUITS=true

# Rate Limiting (requests per 15 minutes)
RATE_LIMIT_MAX=10

# Monitoring (optional)
SENTRY_DSN=
LOG_LEVEL=info